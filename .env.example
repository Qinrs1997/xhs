# ============================================================
# 环境变量模板 — 后端
# ============================================================
# 使用方式:
#   cp .env.example .env
# 然后根据部署环境填写真实值。请勿将 .env 提交到 git！
# ============================================================

# 运行环境: dev / test / prod
# 切换为 prod 时会加载 config/settings.prod.toml 覆盖默认值
APP_ENV=dev

# ==================== 数据库（MySQL，必填）====================
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_database_password
MYSQL_DATABASE=xhs

# ==================== JWT 认证（必填）====================
# 生成方法: python -c "import secrets; print(secrets.token_urlsafe(32))"
# 生产环境必须 ≥32 位随机字符串，且不能是默认占位
SECRET_KEY=your-secret-key-at-least-32-characters-long-random

# Token 过期时间（可选，默认值见 settings.toml）
# ACCESS_TOKEN_EXPIRE_MINUTES=60
# REFRESH_TOKEN_EXPIRE_DAYS=30

# ==================== CORS（生产必填）====================
# ⚠️ 生产环境不能使用 ["*"]，必须是 JSON 数组格式
# 例: BACKEND_CORS_ORIGINS=["https://your-domain.com","https://admin.your-domain.com"]
# BACKEND_CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# ==================== Redis（生产强烈建议开启）====================
# 启用后登录锁定、Token 黑名单、@cached 装饰器均走 Redis
REDIS_ENABLED=false
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# ==================== AI 服务（必填）====================
# 聊天、总结、大纲、文案等文本 AI 能力依赖此 Key
# SiliconFlow: https://siliconflow.cn/
# OpenAI 官方: https://platform.openai.com/api-keys
AI_API_KEY=sk-xxx
# 可选: 切换 AI 网关地址（默认 SiliconFlow）
# AI_BASE_URL=https://api.siliconflow.cn/v1

# ==================== 图片生成（可选，默认 APIMart）====================
# APIMart: https://api.apimart.ai/，用于 gpt-image-2 等图片模型
IMAGE_API_KEY=
IMAGE_BASE_URL=https://api.apimart.ai/v1

# ==================== AI 搜索（启用搜索功能必填）====================
# Tavily 免费额度: 每月 1000 次 https://tavily.com
TAVILY_API_KEY=

# 可选: Brave Search（$5/月付费）
# BRAVE_API_KEY=

# ==================== 邮件服务（注册/找回密码需要）====================
# QQ邮箱获取授权码: 邮箱设置 → 账户 → 开启 SMTP → 获取授权码（非登录密码！）
EMAIL_FROM=your_qq@qq.com
EMAIL_PASSWORD=your_qq_smtp_auth_code

# ==================== 前端地址（邀请链接/支付回调）====================
# 生产环境必须填完整域名，否则支付回调跳转会出错
FRONTEND_URL=http://localhost:3000

# ==================== 对外 API 基址（mock 支付/可点击链接）====================
# Docker/远程部署时必须设置,否则 mock 支付 URL 会指向容器内 localhost
# 示例: PUBLIC_API_BASE=https://api.your-domain.com
# 本机开发可留空,自动回落到 http://127.0.0.1:APP_PORT
PUBLIC_API_BASE=

# ==================== 监控白名单 / Token(METRICS_ENABLED=true 时生效) ====================
# Prometheus 采集方 IP 白名单(CSV 或 CIDR,注意 .env 解析是纯字符串,Pydantic 会逐项 parse)
# 示例: METRICS_ALLOWED_IPS=["127.0.0.1","::1","10.0.0.0/8"]
# METRICS_ALLOWED_IPS=["127.0.0.1","::1"]
# 额外的 Bearer token 校验(可选)
# METRICS_AUTH_TOKEN=

# ==================== 支付宝（如启用支付）====================
# PAYMENT_MODE=mock  # mock / alipay
# ALIPAY_APP_ID=
# ALIPAY_PRIVATE_KEY=
# ALIPAY_PUBLIC_KEY=
# ⚠️ 回调路径以实际路由为准：/api/v1/payment/alipay/notify
# ALIPAY_NOTIFY_URL=https://api.your-domain.com/api/v1/payment/alipay/notify
# ALIPAY_RETURN_URL=https://your-domain.com/payment/success
# ALIPAY_SANDBOX=true

# ==================== 会话（可选）====================
# 如启用 session 中间件
# SESSION_SECRET_KEY=another-random-secret-key-for-session

# ==================== 初始管理员（首次启动）====================
BOOTSTRAP_ADMIN_USERNAME=admin
# ⚠️ 生产环境必须 ≥8 位，不能是 admin123/password/123456 等弱密码
BOOTSTRAP_ADMIN_PASSWORD=change_this_to_strong_password
BOOTSTRAP_ADMIN_EMAIL=admin@your-domain.com
BOOTSTRAP_ADMIN_FULL_NAME=Administrator
